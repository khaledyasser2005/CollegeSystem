@model LoginViewModel

<div class="min-h-screen flex items-center justify-center px-4">

    <div class="w-full max-w-md bg-white shadow-2xl rounded-3xl p-8 border border-gray-100">

        <!-- Logo -->
        <div class="text-center mb-6">
            <div class="mx-auto w-14 h-14 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-xl flex items-center justify-center text-xl font-bold shadow-lg">
                CMS
            </div>

            <h2 class="text-2xl font-bold text-gray-800 mt-4">
                Welcome Back 👋
            </h2>

            <p class="text-gray-500 text-sm mt-1">
                Login to your account
            </p>
        </div>

        <form asp-action="Login" method="post" class="space-y-5">

            <!-- Email -->
            <div>
                <label class="text-sm font-medium text-gray-700">Email</label>
                <input asp-for="Email"
                       placeholder="Enter your email"
                       class="mt-1 w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition" />
                <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
            </div>

            <!-- Password -->
            <div>
                <label class="text-sm font-medium text-gray-700">Password</label>
                <input asp-for="Password" type="password"
                       placeholder="Enter your password"
                       class="mt-1 w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition" />
                <span asp-validation-for="Password" class="text-red-500 text-xs"></span>
            </div>

            <!-- Role -->
            <div>
                <label class="text-sm font-medium text-gray-700">Role</label>
                <select asp-for="Role"
                        class="mt-1 w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
                    <option value="">Select role</option>
                    <option value="Student">Student</option>
                    <option value="Professor">Professor</option>
                    <option value="Admin">Admin</option>
                    <option value="SuperAdmin">Super Admin</option>
                </select>
            </div>

            <!-- Button -->
            <button type="submit"
                    class="w-full py-3 rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-semibold shadow-lg hover:scale-[1.02] transition">
                Login
            </button>

        </form>

        <!-- Footer -->
        <p class="text-center text-sm text-gray-400 mt-6">
            © 2026 DEPI College
        </p>

    </div>

</div>