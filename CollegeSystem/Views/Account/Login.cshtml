@model LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>DEPI College | Login</title>

    <link rel="preconnect"
          href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <script src="https://cdn.tailwindcss.com"></script>

</head>

<body style="font-family:Poppins,sans-serif;
    background:#eef4ff;">

    <div class="min-h-screen flex">

        <!-- LEFT SIDE -->

        <div class="hidden lg:flex w-1/2 relative">

            <img src="/images/login-bg.jpg"
                 class="absolute inset-0 w-full h-full object-cover" />

            <div class="absolute inset-0 bg-blue-950/70"></div>

            <div class="relative z-10 flex flex-col justify-center px-20 text-white">

                <h1 class="text-6xl font-extrabold leading-tight">

                    Welcome To

                    <br>

                    DEPI College

                </h1>

                <p class="mt-8 text-xl leading-9 text-blue-100">

                    Empowering students with modern education,
                    innovation and technology to build
                    successful careers.

                </p>

            </div>

        </div>

        <!-- RIGHT SIDE -->

        <div class="w-full lg:w-1/2 flex items-center justify-center p-10">

            <div class="w-full max-w-md bg-white rounded-[35px] shadow-2xl p-10">

                <div class="text-center">

                    <div class="w-20 h-20 rounded-full bg-blue-100 mx-auto flex items-center justify-center">

                        <i class="fa-solid fa-user text-3xl text-blue-700"></i>

                    </div>

                    <h2 class="mt-5 text-3xl font-bold text-slate-800">

                        Welcome Back

                    </h2>

                    <p class="text-slate-500 mt-2">

                        Login to continue

                    </p>

                </div>

                <form asp-action="Login"
                      method="post"
                      class="mt-8 space-y-5">
                    <!-- Email -->

                    <div>

                        <label class="block mb-2 text-sm font-semibold text-slate-700">

                            Email Address

                        </label>

                        <div class="relative">

                            <i class="fa-solid fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>

                            <input asp-for="Email"
                                   type="email"
                                   placeholder="Enter your email"
                                   class="w-full h-14 pl-12 pr-4 rounded-2xl border border-slate-300 focus:border-blue-600 focus:ring-2 focus:ring-blue-200 outline-none transition" />

                        </div>

                        <span asp-validation-for="Email"
                              class="text-red-500 text-sm"></span>

                    </div>

                    <!-- Password -->

                    <div>

                        <label class="block mb-2 text-sm font-semibold text-slate-700">

                            Password

                        </label>

                        <div class="relative">

                            <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>

                            <input asp-for="Password"
                                   type="password"
                                   placeholder="Enter your password"
                                   class="w-full h-14 pl-12 pr-4 rounded-2xl border border-slate-300 focus:border-blue-600 focus:ring-2 focus:ring-blue-200 outline-none transition" />

                        </div>

                        <span asp-validation-for="Password"
                              class="text-red-500 text-sm"></span>

                    </div>

                    <!-- Role -->

                    <div>

                        <label class="block mb-2 text-sm font-semibold text-slate-700">

                            Select Role

                        </label>

                        <div class="relative">

                            <i class="fa-solid fa-user-graduate absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>

                            <select asp-for="Role"
                                    class="w-full h-14 pl-12 pr-4 rounded-2xl border border-slate-300 focus:border-blue-600 focus:ring-2 focus:ring-blue-200 outline-none appearance-none bg-white">

                                <option value="">Choose your role</option>

                                <option value="Student">Student</option>

                                <option value="Professor">Professor</option>

                                <option value="Admin">Admin</option>

                                <option value="SuperAdmin">Super Admin</option>

                            </select>

                        </div>

                    </div>

                    <button type="submit"
                            class="w-full h-14 rounded-2xl bg-blue-700 hover:bg-blue-800 text-white font-semibold text-lg transition duration-300 shadow-lg hover:shadow-xl">

                        <i class="fa-solid fa-right-to-bracket mr-2"></i>

                        Login

                    </button>
                </form>

                <div class="mt-8 text-center">

                    <p class="text-sm text-slate-500">

                        Secure access to the DEPI College Management System

                    </p>

                </div>

                <div class="mt-8 border-t pt-5 text-center">

                    <p class="text-sm text-slate-400">

                        © 2026 DEPI College. All Rights Reserved.

                    </p>

                </div>

            </div>

        </div>

    </div>

    @section Scripts {

        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }

    }

</body>

</html>