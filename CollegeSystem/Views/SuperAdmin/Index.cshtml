</a>
<div class="my-4 border-t border-white/10"></div>
<a class="flex items-center px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-lg transition-colors" href="#">
<span class="material-symbols-outlined mr-3">library_books</span>
<span class="font-medium">College Courses</span>
</a>
<a class="flex items-center px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-lg transition-colors" href="#">
<span class="material-symbols-outlined mr-3">auto_stories</span>
<span class="font-medium">Student Courses</span>
</a>
<a class="flex items-center px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-lg transition-colors" href="#">
<span class="material-symbols-outlined mr-3">assignment_turned_in</span>
<span class="font-medium">Enroll Courses</span>
</a>
<a class="flex items-center px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-lg transition-colors" href="#">
<span class="material-symbols-outlined mr-3">history_edu</span>
<span class="font-medium">Prof. Courses</span>
</a>
</nav>
<!-- Sidebar Footer -->
<div class="p-4 border-t border-white/10">
<p class="text-xs text-white/40 text-center">© 2023 College Management</p>
</div>
