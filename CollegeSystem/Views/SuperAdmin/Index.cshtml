                  "on-primary-fixed-variant": "#003dab",
                  "tertiary-container": "#5f6265",
                  "secondary": "#555f70",
                  "surface": "#faf8ff",
                  "on-tertiary-container": "#dbdee1",
                  "tertiary": "#474a4d",
                  "error": "#ba1a1a",
                  "primary-fixed-dim": "#b5c4ff",
                  "primary": "#003fb1",
                  "on-secondary-fixed-variant": "#3d4757",
