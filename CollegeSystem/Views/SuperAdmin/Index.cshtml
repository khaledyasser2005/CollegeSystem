<!-- END: Sidebar Navigation -->
<!-- BEGIN: Main Content Area -->
<main class="flex-1 flex flex-col relative overflow-hidden" data-purpose="main-workspace">
<!-- HEADER UPDATED: White background with specific text colors -->
<header class="h-16 flex items-center justify-between px-8 bg-surface-container-lowest border-b border-outline-variant/30 z-20 shrink-0">
<div class="text-lg font-semibold text-on-surface">Welcome Khaled</div>
<a class="text-on-surface-variant hover:text-primary font-medium flex items-center transition-colors group" href="#">
<span>Log out</span>
<span class="material-symbols-outlined ml-2 text-xl group-hover:translate-x-1 transition-transform">logout</span>
</a>
</header>
<!-- END: Top Header -->
