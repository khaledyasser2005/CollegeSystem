          "spacing": {
                  "sm": "8px",
                  "container-max": "1440px",
                  "gutter": "20px",
                  "xl": "32px",
                  "xs": "4px",
                  "lg": "24px",
                  "md": "16px",
                  "2xl": "48px",
                  "base": "4px"
          },
          "fontFamily": {
                  "label-sm": ["IBM Plex Sans"],
                  "body-sm": ["Source Sans 3"],
                  "label-md": ["IBM Plex Sans"],
                  "body-lg": ["Source Sans 3"],
                  "body-md": ["Source Sans 3"],
                  "h3": ["IBM Plex Sans"],
                  "h2": ["IBM Plex Sans"],
                  "h1": ["IBM Plex Sans"]
