                  "body-sm": ["14px", {"lineHeight": "1.4", "fontWeight": "400"}],
                  "label-md": ["14px", {"lineHeight": "1.2", "letterSpacing": "0.02em", "fontWeight": "500"}],
                  "body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
                  "body-md": ["16px", {"lineHeight": "1.5", "fontWeight": "400"}],
                  "h3": ["24px", {"lineHeight": "1.3", "fontWeight": "500"}],
                  "h2": ["30px", {"lineHeight": "1.2", "fontWeight": "600"}],
                  "h1": ["36px", {"lineHeight": "1.2", "fontWeight": "600"}]
          }
        },
      },
    }
  </script>
<style data-purpose="custom-layout-styles">
    body, html {
      height: 100%;
      margin: 0;
      overflow: hidden;
    }
    .main-wrapper {
      display: flex;
      height: 100vh;
      width: 100vw;
      overflow: hidden;
    }
    .sidebar-scroll {
      overflow-y: auto;
      scrollbar-width: thin;
    }
    .sidebar-scroll::-webkit-scrollbar {
      width: 4px;
    }
    .sidebar-scroll::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.1);
      border-radius: 2px;
    }
  </style>
</head>
<body class="font-sans bg-background text-on-surface">
<!-- BEGIN: Main Dashboard Layout -->
<div class="main-wrapper">
<!-- BEGIN: Sidebar Navigation -->
<!-- SIDEBAR UPDATED: Deep dark blue background (on-primary-fixed or inverse-surface equivalent) -->
<aside class="w-64 bg-[#00174d] flex flex-col sidebar-scroll flex-shrink-0" data-purpose="sidebar-container">
<!-- Logo Section -->
<div class="p-6">
<h1 class="text-white font-bold text-xl tracking-tight uppercase">College CMS</h1>
</div>
<!-- Navigation Links -->
<nav class="flex-1 py-4 px-3 space-y-1">
<!-- Active Link: Highlight style matched from Admin Dashboard -->
<a class="flex items-center px-4 py-3 text-white bg-primary-container/40 rounded-lg transition-colors border-l-4 border-primary-fixed-dim" data-purpose="nav-link-active" href="#">
<span class="material-symbols-outlined mr-3 text-white">home</span>
<span class="font-semibold">Home</span>
</a>
<a class="flex items-center px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-lg transition-colors" href="#">
<span class="material-symbols-outlined mr-3">shield_person</span>
<span class="font-medium">Super Admin Dashboard</span>
</a>
<a class="flex items-center px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-lg transition-colors" href="#">
<span class="material-symbols-outlined mr-3">admin_panel_settings</span>
<span class="font-medium">Admin Dashboard</span>
</a>
<div class="my-4 border-t border-white/10"></div>
<a class="flex items-center px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-lg transition-colors" href="#">
<span class="material-symbols-outlined mr-3">group</span>
<span class="font-medium">Students</span>
</a>
<a class="flex items-center px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-lg transition-colors" href="#">
<span class="material-symbols-outlined mr-3">school</span>
