@model CollegeSystem.Models.Course

@{
    ViewData["Title"] = "Course Details";
    var materials = ViewBag.Materials as List<CollegeSystem.Models.Material>;
}

<style>

    body {
        background: #f4f8ff;
    }

    .course-title {
        color: #1f4aa8;
        font-weight: bold;
        margin-bottom: 25px;
    }

    .tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        border-bottom: 2px solid #ddd;
    }

    .tab-btn {
        border: none;
        background: white;
        padding: 12px 22px;
        cursor: pointer;
        border-radius: 10px 10px 0 0;
        font-weight: bold;
        transition: .3s;
    }

        .tab-btn:hover {
            background: #dbe8ff;
        }

        .tab-btn.active {
            background: #1f4aa8;
            color: white;
        }

    .tab-content {
        display: none;
    }

        .tab-content.active {
            display: block;
        }

    .card-box {
        background: white;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 3px 10px rgba(0,0,0,.1);
    }

</style>

<h2 class="course-title">@Model.Name</h2>

<div class="tabs">

    <button class="tab-btn active" onclick="showTab(event,'materials')">
        Materials
    </button>

    <button class="tab-btn" onclick="showTab(event,'assignments')">
        Assignments / Quizzes
    </button>

    <button class="tab-btn" onclick="showTab(event,'students')">
        Students
    </button>

    <button class="tab-btn" onclick="showTab(event,'reports')">
        Reports
    </button>

</div>

<div id="materials" class="tab-content active">

    <div class="card-box">

        <h3>Materials</h3>

        <form asp-action="UploadMaterial"
              asp-controller="Professor"
              method="post"
              enctype="multipart/form-data">

            <input type="hidden" name="courseId" value="@Model.ID" />

            <div class="mb-3">
                <label>Title</label>
                <input class="form-control" type="text" name="title" />
            </div>

            <div class="mb-3">
                <label>Description</label>
                <textarea class="form-control" name="description" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label>Choose PDF</label>
                <input class="form-control" type="file" name="pdfFile" accept=".pdf" />
            </div>

            <div style="margin-top:20px;margin-bottom:35px;">
                <button type="submit"
                        style="background:#0d6efd;
                    color:white;
                    border:none;
                    padding:10px 25px;
                    border-radius:6px;
                    cursor:pointer;
                    font-size:16px;
                    font-weight:bold;">
                    Upload Material
                </button>
            </div>

        </form>

        <hr />

        <h4>Uploaded Materials</h4>
        @{
            var reports = ViewBag.Reports as List<CollegeSystem.Models.Report>;
        }

        @if (materials != null && materials.Any())
        {
            foreach (var item in materials)
            {
                <div class="d-flex justify-content-between align-items-center border rounded p-3 mb-3">

                    <div>
                        <span>📄</span>

                        <a href="@item.FileUrl" target="_blank" style="font-weight:bold;">
                            @item.Title
                        </a>

                        <br />

                        <small>@item.Description</small>
                        <br />
                        <small class="text-muted">@item.UploadDate.ToString("dd/MM/yyyy")</small>
                    </div>

                    <div>
                        <a asp-action="DeleteMaterial"
                               asp-controller="Professor"
                               asp-route-id="@item.ID"
                               asp-route-courseId="@Model.ID"
                               class="btn btn-danger">
                            🗑 Delete
                        </a>
                    </div>

                </div>
            }
        }
        else
        {
            <div class="alert alert-info">No Materials Yet</div>
        }

    </div>

</div>
<!-- ================= ASSIGNMENTS ================= -->
<div id="assignments" class="tab-content">

    <div class="card-box">
        <h3>Assignments / Quizzes</h3>
        <hr />
        <div class="alert alert-secondary">
            Assignment section will be added here.
        </div>
    </div>

</div>

<!-- ================= STUDENTS ================= -->
<div id="students" class="tab-content">
    <div class="card-box">
        <h3>Students Enrolled in this Course</h3>
        <hr />
        @{
            var enrolledStudents = ViewBag.Students as List<CollegeSystem.Models.Student>;
        }
        @if (enrolledStudents != null && enrolledStudents.Any())
        {
            <table class="table table-hover">
                <thead class="table-primary">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Grade</th>
                        <th>Level</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in enrolledStudents)
                    {
                        <tr>
                            <td>@student.Name</td>
                            <td>@student.Email</td>
                            <td>
                                @{
                                    var enrollment = (ViewBag.Enrollments as List<CollegeSystem.Models.Enrollment>)
                                        ?.FirstOrDefault(e => e.StudentID == student.ID);
                                }
                                @(enrollment?.Grade ?? "N/A")
                            </td>
                            <td>@student.Level</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-info">No Students Enrolled Yet</div>
        }
    </div>
</div>

<!-- ================= REPORTS ================= -->
<div id="reports" class="tab-content">

    <div class="card-box">

        <h3>Reports</h3>

        <form asp-action="UploadReport"
              asp-controller="Professor"
              method="post"
              enctype="multipart/form-data">

            <input type="hidden" name="courseId" value="@Model.ID" />

            <div class="mb-3">
                <label>Title</label>
                <input type="text" name="title" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Upload PDF</label>
                <input type="file" name="file" class="form-control" accept="application/pdf" />
            </div>

            <button type="submit"
                    style="background:#0d6efd;
                color:white;
                border:none;
                padding:10px 25px;
                border-radius:6px;
                font-weight:bold;
                cursor:pointer;">
                Upload Report
            </button>

        </form>

        <hr />

       

        @if (reports != null && reports.Any())
        {
            foreach (var item in reports)
            {
                <div class="d-flex justify-content-between align-items-center border rounded p-3 mb-3">

                    <div>
                        <span>📄</span>

                        <a asp-action="DownloadReport"
                               asp-controller="Professor"
                               asp-route-id="@item.ID"
                               style="font-weight:bold;">
                            @item.Title
                        </a>

                        <br />

                        <small class="text-muted">
                            @item.GeneratedDate.ToString("dd/MM/yyyy")
                        </small>
                    </div>

                    <div>
                        <a asp-action="DeleteReport"
                               asp-controller="Professor"
                               asp-route-id="@item.ID"
                               asp-route-courseId="@Model.ID"
                               class="btn btn-danger">
                            🗑
                        </a>
                    </div>

                </div>
            }
        }
        else
        {
            <div class="alert alert-info">
                No Reports Yet
            </div>
        }

    </div>

</div>
<!-- ================= SCRIPT ================= -->
<!-- ================= SCRIPT ================= -->
<script>

    function showTab(event, tabId) {

        var tabs = document.getElementsByClassName("tab-content");

        for (var i = 0; i < tabs.length; i++) {
            tabs[i].classList.remove("active");
        }

        var buttons = document.getElementsByClassName("tab-btn");

        for (var i = 0; i < buttons.length; i++) {
            buttons[i].classList.remove("active");
        }

        document.getElementById(tabId).classList.add("active");
        event.currentTarget.classList.add("active");
    }

    window.onload = function () {

        var activeTab = '@ViewBag.ActiveTab';

        if (activeTab) {
            var btn = document.querySelector("[onclick*='" + activeTab + "']");
            if (btn) {
                btn.click();
            }
        }
    };

</script>