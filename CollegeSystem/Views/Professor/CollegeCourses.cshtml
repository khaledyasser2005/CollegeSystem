@model IEnumerable<CollegeSystem.Models.Course>
@{
    ViewData["Title"] = "College Courses";
}

<section class="min-h-full flex flex-col items-center justify-start bg-surface-container-low px-10 pt-10">

    <div class="text-center mb-10 -mt-2">
        <h1 class="text-4xl font-bold text-on-surface">
            College Courses
        </h1>
        <p class="text-sm text-on-surface-variant mt-2">
            All courses offered by the college
        </p>
    </div>

    <div class="w-full max-w-6xl bg-white rounded-3xl shadow-lg border border-outline-variant p-8">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container text-on-surface-variant text-sm uppercase">
                    <th class="px-6 py-4 rounded-tl-2xl">Course Name</th>
                    <th class="px-6 py-4">Description</th>
                    <th class="px-6 py-4">Duration</th>
                    <th class="px-6 py-4">Semesters</th>
                    <th class="px-6 py-4 rounded-tr-2xl">Prerequisites</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant text-on-surface text-sm">
                @foreach (var course in Model)
                {
                    <tr class="hover:bg-surface-container-low transition">
                        <td class="px-6 py-4 font-medium">@course.Name</td>
                        <td class="px-6 py-4">@course.Description</td>
                        <td class="px-6 py-4">@course.Duration</td>
                        <td class="px-6 py-4">@course.Semesters</td>
                        <td class="px-6 py-4">@course.CoursePrerequisites</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</section>