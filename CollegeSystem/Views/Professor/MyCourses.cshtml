@{
    Layout = null;
    var active = "MyCourses";
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>AcademiaLink - My Courses</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&amp;family=Source+Sans+3:wght@400;500;600&amp;display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
<script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
                  "outline-muted": "#C3C5D7",
                  "on-primary-fixed-variant": "#003dab",
                  "surface-dim": "#d9d9e3",
                  "surface": "#faf8ff",
                  "primary-container": "#1A56DB",
                  "on-background": "#1a1b22",
                  "inverse-on-surface": "#f0f0fa",
                  "surface-container-high": "#e8e7f1",
                  "on-secondary-fixed": "#121c2a",
                  "tertiary-fixed-dim": "#c4c7ca",
                  "on-tertiary": "#ffffff",
                  "tertiary-container": "#474a4d",
                  "background": "#faf8ff",
                  "surface-bright": "#faf8ff",
                  "outline-variant": "#c4c6d6",
                  "surface-variant": "#e2e1eb",
                  "on-tertiary-fixed": "#191c1f",
                  "surface-tint": "#2a56c7",
                  "on-surface": "#191B23",
                  "container-highest": "#E2E1ED",
                  "primary": "#002b80",
                  "on-error-container": "#93000a",
                  "secondary-fixed-dim": "#bdc7db",
                  "surface-container-lowest": "#ffffff",
                  "primary-fixed": "#dbe1ff",
                  "surface-bg": "#FAF8FF",
                  "on-tertiary-container": "#b7b9bd",
                  "on-secondary": "#ffffff",
                  "surface-container-highest": "#e2e1eb",
                  "outline": "#747685",
                  "on-primary": "#ffffff",
                  "secondary": "#555f70",
                  "on-primary-fixed": "#00174c",
                  "inverse-surface": "#2f3038",
                  "surface-container-low": "#f3f3fd",
                  "on-surface-variant": "#434653",
                  "inverse-primary": "#b5c4ff",
                  "tertiary-fixed": "#e1e2e6",
                  "secondary-container": "#d6e0f4",
                  "on-secondary-container": "#596374",
                  "on-tertiary-fixed-variant": "#44474a",
                  "surface-container": "#ededf7",
                  "error-container": "#ffdad6",
                  "on-error": "#ffffff",
                  "tertiary": "#303436",
                  "primary-fixed-dim": "#b5c4ff",
                  "on-primary-container": "#a1b6ff",
                  "secondary-fixed": "#d9e3f7",
                  "error": "#ba1a1a",
                  "on-secondary-fixed-variant": "#3d4757"
          },
          "borderRadius": { "DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem" },
          "spacing": { "gutter": "20px", "md": "16px", "lg": "24px", "xs": "4px", "sm": "8px", "xl": "32px", "base": "4px", "2xl": "48px", "container-max": "1440px" },
          "fontFamily": {
                  "body-md": ["Source Sans 3"], "h2": ["IBM Plex Sans"], "label-sm": ["IBM Plex Sans"],
                  "body-sm": ["Source Sans 3"], "h1": ["IBM Plex Sans"], "body-lg": ["Source Sans 3"],
                  "label-md": ["IBM Plex Sans"], "h3": ["IBM Plex Sans"]
          },
          "fontSize": {
                  "body-md": ["16px", {"lineHeight": "1.5", "fontWeight": "400"}],
                  "h2": ["30px", {"lineHeight": "1.2", "fontWeight": "600"}],
                  "label-sm": ["12px", {"lineHeight": "1.2", "letterSpacing": "0.05em", "fontWeight": "600"}],
                  "body-sm": ["14px", {"lineHeight": "1.4", "fontWeight": "400"}],
                  "h1": ["36px", {"lineHeight": "1.2", "fontWeight": "600"}],
                  "body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
                  "label-md": ["14px", {"lineHeight": "1.2", "letterSpacing": "0.02em", "fontWeight": "500"}],
                  "h3": ["24px", {"lineHeight": "1.3", "fontWeight": "500"}]
          }
        },
      },
    }
  </script>
<style>
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
</style>
</head>
<body class="bg-background text-on-surface font-body-md antialiased min-h-screen">
<!-- SideNavBar -->
<aside class="bg-primary h-screen w-64 fixed left-0 top-0 shadow-sm flex flex-col py-lg px-md z-20">
<div class="mb-xl px-sm">
<h1 class="font-h2 text-h2 font-semibold text-white">AcademiaLink</h1>
<p class="font-label-sm text-label-sm text-white/80 uppercase tracking-wider mt-xs">Professor Dashboard</p>
</div>
<nav class="flex-1 space-y-sm">
<a class="flex items-center gap-md p-md rounded transition-colors @(active=="Home" ? "bg-white text-primary font-bold" : "text-white/90 hover:bg-white/10")" asp-controller="Professor" asp-action="Home">
<span class="material-symbols-outlined @(active=="Home" ? "text-primary" : "text-white")">home</span>
<span class="font-label-md text-label-md">Home</span>
</a>
<a class="flex items-center gap-md p-md rounded transition-colors @(active=="MyCourses" ? "bg-white text-primary font-bold" : "text-white/90 hover:bg-white/10")" asp-controller="Professor" asp-action="MyCourses">
<span class="material-symbols-outlined @(active=="MyCourses" ? "text-primary" : "text-white")">menu_book</span>
<span class="font-label-md text-label-md">My Courses</span>
</a>
<a class="flex items-center gap-md p-md rounded transition-colors @(active=="Students" ? "bg-white text-primary font-bold" : "text-white/90 hover:bg-white/10")" asp-controller="Professor" asp-action="Students">
<span class="material-symbols-outlined @(active=="Students" ? "text-primary" : "text-white")">group</span>
<span class="font-label-md text-label-md">Students</span>
</a>
<a class="flex items-center gap-md p-md rounded transition-colors @(active=="Professors" ? "bg-white text-primary font-bold" : "text-white/90 hover:bg-white/10")" asp-controller="Professor" asp-action="Professors">
<span class="material-symbols-outlined @(active=="Professors" ? "text-primary" : "text-white")">school</span>
<span class="font-label-md text-label-md">Professors</span>
</a>
<a class="flex items-center gap-md p-md rounded transition-colors @(active=="CollegeCourses" ? "bg-white text-primary font-bold" : "text-white/90 hover:bg-white/10")" asp-controller="Professor" asp-action="CollegeCourses">
<span class="material-symbols-outlined @(active=="CollegeCourses" ? "text-primary" : "text-white")">library_books</span>
<span class="font-label-md text-label-md">College Courses</span>
</a>
</nav>
<div class="mt-auto pt-lg">
<a class="flex items-center gap-md p-md rounded text-white/90 hover:bg-white/10 transition-colors" asp-controller="Account" asp-action="Login">
<span class="material-symbols-outlined text-white">logout</span>
<span class="font-label-md text-label-md">Logout</span>
</a>
</div>
</aside>
<!-- TopAppBar -->
<header class="fixed top-0 right-0 left-64 z-10 bg-surface border-b border-outline-variant flex justify-between items-center h-16 px-lg max-w-container-max">
<div class="flex items-center gap-xl">
<h2 class="font-h3 text-h3 text-primary">Welcome back, Professor</h2>
</div>
<div class="flex items-center gap-lg">
<div class="relative group">
<input class="bg-surface-container-low border-none focus:ring-1 focus:ring-primary rounded-full px-md py-sm text-body-sm w-64 transition-all" placeholder="Search..." type="text">
<span class="material-symbols-outlined absolute right-sm top-1/2 -translate-y-1/2 text-outline">search</span>
</div>
<button class="material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors">notifications</button>
<div class="h-8 w-8 rounded-full bg-secondary-container flex items-center justify-center text-on-secondary-container font-bold border border-outline-variant">P</div>
</div>
</header>
<!-- Main Content -->
<main class="ml-64 pt-16 min-h-screen">
<div class="max-w-container-max mx-auto p-lg">
<div class="mb-xl flex justify-between items-end">
<div>
<h1 class="font-h1 text-h1 text-primary mb-xs">My Courses</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant">Courses you are currently teaching this semester.</p>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-gutter">
<div class="bg-surface-container-lowest rounded-xl p-lg shadow-sm border border-outline-variant flex flex-col gap-lg hover:shadow-md transition-shadow">
<div class="flex justify-between items-start">
<div class="w-12 h-12 rounded-full bg-secondary-container flex items-center justify-center text-on-secondary-container">
<span class="material-symbols-outlined">computer</span>
</div>
<span class="px-sm py-xs bg-surface-container-high rounded text-label-sm text-on-surface-variant">CS402</span>
</div>
<div>
<h3 class="font-h3 text-h3 text-primary mb-xs">Advanced Systems Architecture</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">3 Assignments &middot; 42 Students enrolled</p>
</div>
<div class="mt-auto pt-md border-t border-outline-variant/30">
<button class="w-full py-sm bg-primary text-on-primary rounded-xl font-bold flex items-center justify-center gap-sm active:scale-95 transition-all">
Open Course
<span class="material-symbols-outlined text-[18px]">open_in_new</span>
</button>
</div>
</div>
<div class="bg-surface-container-lowest rounded-xl p-lg shadow-sm border border-outline-variant flex flex-col gap-lg hover:shadow-md transition-shadow">
<div class="flex justify-between items-start">
<div class="w-12 h-12 rounded-full bg-secondary-container flex items-center justify-center text-on-secondary-container">
<span class="material-symbols-outlined">functions</span>
</div>
<span class="px-sm py-xs bg-surface-container-high rounded text-label-sm text-on-surface-variant">MAT202</span>
</div>
<div>
<h3 class="font-h3 text-h3 text-primary mb-xs">Applied Mathematics</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">2 Assignments &middot; 38 Students enrolled</p>
</div>
<div class="mt-auto pt-md border-t border-outline-variant/30">
<button class="w-full py-sm bg-primary text-on-primary rounded-xl font-bold flex items-center justify-center gap-sm active:scale-95 transition-all">
Open Course
<span class="material-symbols-outlined text-[18px]">open_in_new</span>
</button>
</div>
</div>
<div class="bg-surface-container-lowest rounded-xl p-lg shadow-sm border border-outline-variant flex flex-col gap-lg hover:shadow-md transition-shadow">
<div class="flex justify-between items-start">
<div class="w-12 h-12 rounded-full bg-secondary-container flex items-center justify-center text-on-secondary-container">
<span class="material-symbols-outlined">science</span>
</div>
<span class="px-sm py-xs bg-surface-container-high rounded text-label-sm text-on-surface-variant">PHYS101</span>
</div>
<div>
<h3 class="font-h3 text-h3 text-primary mb-xs">Introduction to Astrophysics</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">4 Assignments &middot; 51 Students enrolled</p>
</div>
<div class="mt-auto pt-md border-t border-outline-variant/30">
<button class="w-full py-sm bg-primary text-on-primary rounded-xl font-bold flex items-center justify-center gap-sm active:scale-95 transition-all">
Open Course
<span class="material-symbols-outlined text-[18px]">open_in_new</span>
</button>
</div>
</div>
</div>
</div>
</main>
</body>
</html>
