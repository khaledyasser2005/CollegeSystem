@using CollegeSystem.Models
@model List<CollegeSystem.Models.Course>

@{
    ViewData["Title"] = "Professors Course Assignment";
    var professors = ViewBag.Professors as List<Professor>;
}

<style>
    .page-title {
        color: #1e3a5f;
        font-size: 28px;
        font-weight: bold;
    }

    .card-box {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 5px 15px rgba(0,0,0,.08);
        width: 100%;
        max-width: 600px;
    }

    .form-label {
        font-size: 14px;
        font-weight: 600;
        color: #1e3a5f;
        margin-bottom: 8px;
        display: block;
    }

    .form-select {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #dbe8ff;
        border-radius: 10px;
        outline: none;
        font-size: 14px;
        transition: .2s;
    }

        .form-select:focus {
            border-color: #2f55a4;
            box-shadow: 0 0 0 2px rgba(47,85,164,.1);
        }

    .submit-btn {
        width: 100%;
        background: #2f55a4;
        color: white;
        font-weight: 600;
        padding: 12px;
        border-radius: 10px;
        border: none;
        transition: .2s;
        cursor: pointer;
    }

        .submit-btn:hover {
            background: #24478c;
        }

    .success-box {
        margin-bottom: 20px;
        padding: 12px;
        background: #eaffea;
        border: 1px solid #b2f0b2;
        border-radius: 10px;
        color: #276227;
        font-size: 13px;
    }

    .error-box {
        margin-bottom: 20px;
        padding: 12px;
        background: #ffeaea;
        border: 1px solid #ffbcbc;
        border-radius: 10px;
        color: #c53030;
        font-size: 13px;
    }
</style>

<section class="flex flex-col items-center pt-8">

    <!-- Title -->
    <div style="margin-bottom: 25px; text-align:center;">
        <h1 class="page-title">Professors Course Assignment</h1>
        <p style="color:#666;">Assign or unassign courses from professors</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="success-box" style="width:100%; max-width:1240px;">
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="error-box" style="width:100%; max-width:1240px;">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="flex flex-col md:flex-row gap-6 w-full justify-center">

        <!-- ASSIGN CARD -->
        <div class="card-box">

            <div style="margin-bottom:20px;">
                <h2 style="color:#1e3a5f; font-size:18px; font-weight:700; margin-bottom:4px;">
                    Assign Course
                </h2>
                <p style="color:#666; font-size:13px;">Select a professor and a course to assign</p>
            </div>

            <form method="post" asp-action="AssignCourseToProfessor" asp-controller="Admin">
                @Html.AntiForgeryToken()

                <div style="margin-bottom:20px;">
                    <label class="form-label">Professor</label>
                    <select name="ProfessorID" class="form-select">
                        <option value="">-- Select Professor --</option>
                        @if (professors != null)
                        {
                            foreach (var p in professors)
                            {
                                <option value="@p.ID">@p.Name</option>
                            }
                        }
                    </select>
                </div>

                <div style="margin-bottom:25px;">
                    <label class="form-label">Course</label>
                    <select name="CourseID" class="form-select">
                        <option value="">-- Select Course --</option>
                        @foreach (var c in Model)
                        {
                            <option value="@c.ID">@c.Name</option>
                        }
                    </select>
                </div>

                <button type="submit" class="submit-btn">
                    Assign Course
                </button>

            </form>
        </div>

        <!-- UNASSIGN CARD -->
        <div class="card-box">

            <div style="margin-bottom:20px;">
                <h2 style="color:#1e3a5f; font-size:18px; font-weight:700; margin-bottom:4px;">
                    Unassign Course
                </h2>
                <p style="color:#666; font-size:13px;">Select a professor and a course to unassign</p>
            </div>

            <form method="post" asp-action="UnassignCourseFromProfessor" asp-controller="Admin"
                  onsubmit="return confirm('Are you sure you want to unassign this course?');">
                @Html.AntiForgeryToken()

                <div style="margin-bottom:20px;">
                    <label class="form-label">Professor</label>
                    <select name="ProfessorID" class="form-select">
                        <option value="">-- Select Professor --</option>
                        @if (professors != null)
                        {
                            foreach (var p in professors)
                            {
                                <option value="@p.ID">@p.Name</option>
                            }
                        }
                    </select>
                </div>

                <div style="margin-bottom:25px;">
                    <label class="form-label">Course</label>
                    <select name="CourseID" class="form-select">
                        <option value="">-- Select Course --</option>
                        @foreach (var c in Model.Where(c => c.ProfessorID != null).ToList())
                        {
                            <option value="@c.ID">@c.Name</option>
                        }
                    </select>
                </div>

                <button type="submit" class="submit-btn">
                    Unassign Course
                </button>

            </form>
        </div>

    </div>

</section>