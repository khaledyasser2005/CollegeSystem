@model Dictionary<int, List<CollegeSystem.Models.Student>>

@{
    ViewData["Title"] = "College Tab";

    var students = Model
        .SelectMany(group => group.Value)
        .OrderBy(student => student.Name)
        .ToList();
}

<style>
    .page-header {
        text-align: center;
        margin-bottom: 28px;
    }

    .page-header h1 {
        color: #1f4aa8;
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .page-header p {
        color: #667085;
        font-size: 14px;
    }

    .search-box {
        width: 100%;
        max-width: 720px;
        margin: 0 auto 24px;
        position: relative;
    }

    .search-box input {
        width: 100%;
        background: white;
        padding: 14px 18px;
        border: 1px solid #d0d5dd;
        border-radius: 14px;
        font-size: 15px;
        outline: none;
        transition: .3s;
        box-shadow: 0 4px 12px rgba(15, 23, 42, .08);
    }

    .search-box input:focus {
        border-color: #1f4aa8;
        box-shadow: 0 0 0 3px rgba(31, 74, 168, .08), 0 4px 12px rgba(15, 23, 42, .08);
    }

    .tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        border-bottom: 2px solid #ddd;
        flex-wrap: wrap;
    }

    .tab-btn {
        border: none;
        background: #1f4aa8;
        color: white;
        padding: 12px 22px;
        border-radius: 10px 10px 0 0;
        font-weight: bold;
        font-size: 15px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .badge-level {
        background: white;
        color: #1f4aa8;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 12px;
    }

    .tab-content {
        display: block;
    }

    .card-box {
        background: white;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 3px 10px rgba(0,0,0,.1);
    }

    .table-wrap {
        width: 100%;
        overflow-x: auto;
    }

    .students-table {
        width: 100%;
        min-width: 760px;
        border-collapse: separate;
        border-spacing: 0;
        margin-top: 10px;
    }

    .students-table thead tr {
        background: #1f4aa8;
        color: white;
    }

    .students-table thead th {
        padding: 14px 18px;
        font-weight: 600;
        font-size: 14px;
        text-align: left;
        white-space: nowrap;
    }

    .students-table thead th:first-child {
        border-radius: 10px 0 0 0;
    }

    .students-table thead th:last-child {
        border-radius: 0 10px 0 0;
    }

    .students-table tbody tr {
        border-bottom: 1px solid #eef2ff;
        transition: background .2s;
    }

    .students-table tbody tr:hover {
        background: #f0f5ff;
    }

    .students-table tbody td {
        padding: 14px 18px;
        font-size: 14px;
        color: #333;
        vertical-align: middle;
    }

    .level-badge {
        background: #eef2ff;
        color: #1f4aa8;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 12px;
        font-weight: bold;
        white-space: nowrap;
    }

    .course-tag {
        display: inline-block;
        background: #f0f5ff;
        color: #1f4aa8;
        border-radius: 6px;
        padding: 3px 9px;
        font-size: 12px;
        margin: 2px;
    }

    .num-cell {
        color: #888;
        font-weight: bold;
        width: 40px;
    }

    .no-results {
        text-align: center;
        color: #888;
        padding: 30px;
        font-size: 15px;
    }
</style>

<section class="min-h-full bg-surface-container-low px-4 sm:px-10 pt-4">
    <div class="page-header">
        <h1>Courses</h1>
        <p>View assigned courses across all college students</p>
    </div>

    <div class="tabs">
        <button class="tab-btn" type="button">
            College Tab
            <span class="badge-level">@students.Count</span>
        </button>
    </div>

    <div class="tab-content">
        <div class="search-box">
            <input type="text" id="searchInput" placeholder="Search students by name..." onkeyup="searchStudents()" />
        </div>

        <div class="card-box">
            <h4 style="color:#1f4aa8; margin-bottom:20px; font-size:17px;">
                College Students - <span style="color:#555;">@students.Count Students</span>
            </h4>

            @if (students.Any())
            {
                <div class="table-wrap">
                    <table class="students-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Grade</th>
                                <th>Level</th>
                                <th>Courses</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int i = 1; }
                            @foreach (var student in students)
                            {
                                var grades = student.Enrollments?
                                    .Where(e => e.Grade != null)
                                    .Select(e => e.Grade)
                                    .ToList();

                                var courses = student.Enrollments?
                                    .Select(e => e.Course?.Name)
                                    .Where(n => n != null)
                                    .ToList();

                                <tr class="student-row">
                                    <td class="num-cell">@i</td>
                                    <td class="student-name" style="font-weight:600;">@student.Name</td>
                                    <td style="color:#555;">@student.Email</td>
                                    <td>
                                        @if (grades != null && grades.Any())
                                        {
                                            <span style="font-weight:bold; color:#1f4aa8;">@string.Join(", ", grades)</span>
                                        }
                                        else
                                        {
                                            <span style="color:#aaa;">N/A</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="level-badge">Level @student.Level</span>
                                    </td>
                                    <td>
                                        @if (courses != null && courses.Any())
                                        {
                                            foreach (var course in courses)
                                            {
                                                <span class="course-tag">@course</span>
                                            }
                                        }
                                        else
                                        {
                                            <span style="color:#aaa;">No Courses</span>
                                        }
                                    </td>
                                </tr>
                                i++;
                            }
                        </tbody>
                    </table>
                </div>

                <div class="no-results" id="noResults" style="display:none;">
                    No students found matching your search.
                </div>
            }
            else
            {
                <div class="no-results">No students found.</div>
            }
        </div>
    </div>
</section>

<script>
    function searchStudents() {
        var input = document.getElementById("searchInput");
        var query = input.value.toLowerCase();
        var rows = document.querySelectorAll(".student-row");
        var visibleCount = 0;

        rows.forEach(function (row) {
            var name = row.querySelector(".student-name").textContent.toLowerCase();
            if (name.includes(query)) {
                row.style.display = "";
                visibleCount++;
            } else {
                row.style.display = "none";
            }
        });

        var noResults = document.getElementById("noResults");
        if (noResults) {
            noResults.style.display = visibleCount === 0 && rows.length > 0 ? "block" : "none";
        }
    }
</script>
