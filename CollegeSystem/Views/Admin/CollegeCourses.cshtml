@model IEnumerable<CollegeSystem.Models.Course>

@{
    ViewData["Title"] = "College Courses";
}

<style>
    .card-box {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 5px 15px rgba(0,0,0,.08);
    }

    .students-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin-top: 10px;
    }

    .students-table thead tr {
        background: #2f55a4;
        color: white;
    }

    .students-table thead th {
        padding: 14px 18px;
        font-size: 14px;
        text-align: left;
    }

    .students-table tbody tr {
        border-bottom: 1px solid #eef2ff;
        transition: .2s;
    }

    .students-table tbody tr:hover {
        background: #f5f8ff;
    }

    .students-table td {
        padding: 14px 18px;
        font-size: 14px;
    }

    .search-box {
        max-width: 400px;
        margin-bottom: 20px;
    }

    .search-box input {
        width: 100%;
        padding: 10px 15px;
        border: 2px solid #dbe8ff;
        border-radius: 10px;
        outline: none;
    }

    .search-box input:focus {
        border-color: #2f55a4;
    }

    .no-results {
        text-align: center;
        padding: 20px;
        color: #888;
        display: none;
    }
</style>

<section class="px-10 pt-6">

    <!-- Title -->
    <div style="margin-bottom: 25px;">
        <h1 style="color:#1e3a5f; font-size:28px; font-weight:bold;">
        College Courses
        </h1>
        <p style="color:#666;">
            Browse all available courses in the college
        </p>
    </div>

    <!-- Search -->
    <div class="search-box">
        <input type="text" id="searchInput" placeholder="Search course by name..." onkeyup="searchCourses()" />
    </div>

    <!-- Table -->
    <div class="card-box">
        <table class="students-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Course Name</th>
                    <th>Description</th>
                    <th>Duration</th>
                    <th>Semesters</th>
                    <th>Prerequisites</th>
                    <th>Professor</th>
                </tr>
            </thead>

            <tbody id="coursesTable">
                @foreach (var course in Model)
                {
                        <tr class="course-row">
                            <td>@course.ID</td>
                            <td class="course-name" style="font-weight:600;">@course.Name</td>
                            <td>@course.Description</td>
                            <td>@course.Duration</td>
                            <td>@course.Semesters</td>
                            <td>@course.CoursePrerequisites</td>
                        <td>@(course.Professor?.Name ?? "No Professor")</td>
                        </tr>
                }
            </tbody>
        </table>

        <div id="noResults" class="no-results">
            No courses found
        </div>
    </div>

</section>

<script>
    function searchCourses() {
        var input = document.getElementById("searchInput").value.toLowerCase();
        var rows = document.querySelectorAll(".course-row");
        var visible = 0;

        rows.forEach(function (row) {
            var name = row.querySelector(".course-name").textContent.toLowerCase();

            if (name.includes(input)) {
                row.style.display = "";
                visible++;
            } else {
                row.style.display = "none";
            }
        });

        document.getElementById("noResults").style.display =
            visible === 0 ? "block" : "none";
    }
</script>