@{
    var professors = ViewBag.Professors as List<CollegeSystem.Models.Professor>;
    var courses = ViewBag.Courses as List<CollegeSystem.Models.Course>;
}

<style>
    body {
        background: #f4f8ff;
    }

    .box {
        width: 50%;
        margin: 50px auto;
        background: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        border-top: 5px solid #1f4aa8;
    }

    h2 {
        text-align: center;
        color: #1f4aa8;
        margin-bottom: 20px;
    }

    label {
        font-weight: bold;
        color: #1f4aa8;
    }

    select {
        width: 100%;
        padding: 10px;
        margin: 10px 0;
        border-radius: 8px;
        border: 1px solid #ccc;
    }

    button {
        width: 100%;
        padding: 10px;
        background: #1f4aa8;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        button:hover {
            background: #163a80;
        }
</style>

<div class="box">
    <h2>Assign Course To Professor</h2>

    <form method="post">
        <label>Professor</label>
        <select name="professorId">
            @foreach (var p in professors)
            {
                <option value="@p.ID">@p.Name</option>
            }
        </select>

        <label>Course</label>
        <select name="courseId">
            @foreach (var c in courses)
            {
                <option value="@c.ID">@c.Name</option>
            }
        </select>

        <button type="submit">Assign</button>
    </form>
</div>