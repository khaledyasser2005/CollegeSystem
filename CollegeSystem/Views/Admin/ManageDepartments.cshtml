@{
    ViewData["Title"] = "Manage Departments";
}

<section class="min-h-full flex flex-col items-center justify-start bg-surface-container-low px-10 pt-10">

    <!-- Title -->
    <div class="text-center mb-10 -mt-2">
        <h1 class="text-4xl font-bold text-on-surface">
            Manage Departments
        </h1>
        <p class="text-sm text-on-surface-variant mt-2">
            Add, Update and Delete Departments
        </p>
    </div>

    <!-- Cards Container -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full max-w-6xl">

        <!-- ================= ADD DEPARTMENT ================= -->
        <div class="bg-white rounded-3xl shadow-lg border border-outline-variant p-8">

            <h2 class="text-2xl font-semibold text-center mb-6">Add Department</h2>

            <form asp-controller="Admin" asp-action="AddDepartment" method="post" class="space-y-5">

                <!-- Department Name -->
                <input type="text" name="Name" placeholder="Department Name"
                       class="w-full rounded-xl border px-4 py-3 focus:ring-2 focus:ring-blue-500" />

                <!-- GPA Required -->
                <input type="number" step="0.01" name="GpaRequired" placeholder="GPA Required"
                       class="w-full rounded-xl border px-4 py-3 focus:ring-2 focus:ring-blue-500" />

                <button type="submit"
                        class="w-full bg-blue-600 text-white py-3 rounded-xl hover:bg-blue-700 transition">
                    Add
                </button>

            </form>
        </div>

        <!-- ================= UPDATE DEPARTMENT ================= -->
        <div class="bg-white rounded-3xl shadow-lg border border-outline-variant p-8">

            <h2 class="text-2xl font-semibold text-center mb-6">Update Department</h2>

            <form asp-controller="Admin" asp-action="UpdateDepartment" method="post" class="space-y-5">

                <!-- ID -->
                <input type="number" name="Id" placeholder="Department ID"
                       class="w-full rounded-xl border px-4 py-3 focus:ring-2 focus:ring-blue-500" />

                <!-- New Name -->
                <input type="text" name="Name" placeholder="New Department Name"
                       class="w-full rounded-xl border px-4 py-3 focus:ring-2 focus:ring-blue-500" />

                <!-- New GPA -->
                <input type="number" step="0.01" name="GpaRequired" placeholder="New GPA Required"
                       class="w-full rounded-xl border px-4 py-3 focus:ring-2 focus:ring-blue-500" />

                <button type="submit"
                        class="w-full bg-yellow-500 text-white py-3 rounded-xl hover:bg-yellow-600 transition">
                    Update
                </button>

            </form>
        </div>

        <!-- ================= DELETE DEPARTMENT ================= -->
        <div class="bg-white rounded-3xl shadow-lg border border-outline-variant p-8">

            <h2 class="text-2xl font-semibold text-center mb-6">Delete Department</h2>

            <form asp-controller="Admin" asp-action="DeleteDepartment" method="post" class="space-y-5">

                <input type="number" name="Id" placeholder="Department ID"
                       class="w-full rounded-xl border px-4 py-3 focus:ring-2 focus:ring-red-500" />

                <button type="submit"
                        class="w-full bg-red-600 text-white py-3 rounded-xl hover:bg-red-700 transition">
                    Delete
                </button>

            </form>
        </div>

    </div>

</section>