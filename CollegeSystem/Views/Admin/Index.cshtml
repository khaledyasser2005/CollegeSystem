@{
    Layout = null;
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>AcademiaLink - Admin Dashboard</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Source+Sans+3:wght@400;500;600&family=Material+Symbols+Outlined" rel="stylesheet">

    <!-- Tailwind Config (IMPORTANT FOR COLORS) -->
    <script>
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        colors: {
        background: "#faf8ff",
        "on-surface": "#191b23",
        primary: "#003fb1",
        "primary-container": "#1a56db",
        "surface-container-low": "#f3f3fe",
        "surface-container-lowest": "#ffffff",
        "on-surface-variant": "#434654",
        outline: "#737686"
        }
        }
        }
        }
    </script>

    <style>
        .sidebar-item { transition: all 0.2s ease; }
        .sidebar-item:not(.active):hover { background-color: rgba(0, 63, 177, 0.08); }
    </style>
</head>

<body class="bg-background text-on-surface font-body-md min-h-screen">

    <div class="flex h-screen overflow-hidden">

        <!-- Sidebar -->
        <aside class="w-64 bg-surface-container-low border-r border-outline flex flex-col">

            <div class="px-6 py-6">
                <span class="text-xl font-bold text-primary">COLLEGE CMS</span>
            </div>

            <nav class="flex-1 px-3 space-y-2">

                <a href="#" onclick="loadTab('Home')" class="sidebar-item block px-4 py-2 rounded text-on-surface-variant">Home</a>
                <a href="#" onclick="loadTab('AdminDashboard')" class="sidebar-item block px-4 py-2 rounded text-on-surface-variant">Admin Dashboard</a>
                <a href="#" onclick="loadTab('CollegeCourses')" class="sidebar-item block px-4 py-2 rounded text-on-surface-variant">College Courses</a>
                <a href="#" onclick="loadTab('AssignCourseToStudent')" class="sidebar-item block px-4 py-2 rounded text-on-surface-variant">Assign Student</a>
                <a href="#" onclick="loadTab('AssignCourseToProfessor')" class="sidebar-item block px-4 py-2 rounded text-on-surface-variant">Assign Professor</a>

            </nav>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col">

            <!-- Header -->
            <header class="h-16 bg-white border-b flex items-center justify-between px-6">
                <h1 class="font-bold text-lg">Welcome Admin</h1>
                <span class="text-sm text-gray-500">admin@college.edu</span>
            </header>

            <!-- Dynamic Content -->
            <main class="flex-1 p-6 overflow-y-auto">

                <div id="contentArea">

                    <!-- Default Home Content -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                        <section class="bg-white p-6 rounded shadow">
                            <h2 class="text-xl font-bold text-blue-700">Add Professor</h2>
                        </section>

                        <section class="bg-white p-6 rounded shadow">
                            <h2 class="text-xl font-bold text-blue-700">Add Student</h2>
                        </section>

                    </div>

                </div>

            </main>

        </div>
    </div>

    <!-- JS Tabs -->
    <script>
        function loadTab(page) {
        fetch('/Admin/' + page)
        .then(res => res.text())
        .then(html => {
        document.getElementById('contentArea').innerHTML = html;
        })
        .catch(() => {
        document.getElementById('contentArea').innerHTML =
        "<h2 style='color:red'>Error loading page</h2>";
        });
        }
    </script>

</body>
</html>