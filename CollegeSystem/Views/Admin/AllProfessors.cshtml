@model List<CollegeSystem.Models.Professor>

@{
    ViewData["Title"] = "All Professors";
}

<section class="p-10 bg-surface-container-low min-h-screen">

    <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-on-surface">
            All Professors
        </h1>
        <p class="text-sm text-on-surface-variant mt-2">
            Browse and search all professors in the system
        </p>
    </div>

    <div class="max-w-5xl mx-auto">

        <!-- Search Bar -->
        <form asp-action="AllProfessors" asp-controller="Admin" method="get" class="mb-6 flex gap-3">
            <input type="text"
                   name="searchName"
                   value="@ViewBag.SearchName"
                   placeholder="Search professor by name..."
                   class="form-control"
                   style="flex:1; padding:10px 15px; border-radius:8px; border:1px solid #ccc;" />

            <button type="submit"
                    style="background:#0d6efd;color:white;border:none;padding:10px 25px;border-radius:6px;cursor:pointer;font-weight:bold;">
                Search
            </button>

            <a asp-action="AllProfessors" asp-controller="Admin"
               style="background:#6c757d;color:white;border:none;padding:10px 25px;border-radius:6px;cursor:pointer;font-weight:bold;text-decoration:none;display:inline-block;">
                Reset
            </a>
        </form>

        <!-- Professors Table -->
        <div class="bg-white rounded-2xl shadow-md p-6 border border-gray-200">

            @if (Model != null && Model.Any())
            {
                <table class="w-full" style="border-collapse:collapse;">
                    <thead>
                        <tr style="border-bottom:2px solid #eee;">
                            <th style="text-align:left;padding:10px;">ID</th>
                            <th style="text-align:left;padding:10px;">Name</th>
                            <th style="text-align:left;padding:10px;">Email</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prof in Model)
                        {
                            <tr style="border-bottom:1px solid #f0f0f0;">
                                <td style="padding:10px;">@prof.ID</td>
                                <td style="padding:10px;">@prof.Name</td>
                                <td style="padding:10px;">@prof.Email</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info">No Professors Found</div>
            }

        </div>

    </div>

</section>
