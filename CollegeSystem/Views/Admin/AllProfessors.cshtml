@model List<CollegeSystem.Models.Professor>

@{
    ViewData["Title"] = "College Professors";
}

<section class="p-10 bg-surface-container-low min-h-screen">

    <div class="text-center mb-8">
        <h1 class="text-4xl font-bold" style="color:#1e3a8a;">
            College Professors
        </h1>
        <p class="text-sm text-on-surface-variant mt-2">
            Browse and search all professors in the system
        </p>
    </div>

    <div class="max-w-5xl mx-auto">

        <!-- Search Bar -->
        <div class="mb-6 flex gap-3">
            <input type="text"
                   id="searchNameInput"
                   value="@ViewBag.SearchName"
                   placeholder="Search professor by name..."
                   class="form-control"
                   style="flex:1; padding:10px 15px; border-radius:8px; border:1px solid #ccc;" />
        </div>

        <!-- Professors Table -->
        <div class="bg-white rounded-2xl shadow-md p-6 border border-gray-200" id="professorsTableContainer">

            @if (Model != null && Model.Any())
            {
                <table class="w-full" style="border-collapse:collapse;">
                    <thead>
                        <tr style="border-bottom:2px solid #eee;">
                            <th style="text-align:left;padding:10px;">ID</th>
                            <th style="text-align:left;padding:10px;">Name</th>
                            <th style="text-align:left;padding:10px;">Email</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prof in Model)
                        {
                            <tr style="border-bottom:1px solid #f0f0f0;">
                                <td style="padding:10px;">@prof.ID</td>
                                <td style="padding:10px;">@prof.Name</td>
                                <td style="padding:10px;">@prof.Email</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info">No Professors Found</div>
            }

        </div>

        <script>
                    let searchTimer;

                    document.getElementById('searchNameInput').addEventListener('input', function () {
                        clearTimeout(searchTimer);
                        const value = this.value;

                        searchTimer = setTimeout(function () {
                            fetch('/Admin/AllProfessors?searchName=' + encodeURIComponent(value), {
                                headers: { 'X-Requested-With': 'XMLHttpRequest' }
                            })
                                .then(response => response.text())
                                .then(html => {
                                    document.getElementById('professorsTableContainer').innerHTML = html;
                                });
                        }, 300);
                    });

                    function resetSearch() {
                        document.getElementById('searchNameInput').value = '';
                        document.getElementById('searchNameInput').dispatchEvent(new Event('input'));
                    }
        </script>

    </div>

</section>
