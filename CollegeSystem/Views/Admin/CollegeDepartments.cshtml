@model IEnumerable<CollegeSystem.Models.Department>

@{
    ViewData["Title"] = "College Departments";
    var departments = Model?.OrderBy(d => d.Name).ToList() ?? new List<CollegeSystem.Models.Department>();
}

<style>
    body {
        background: #f5f8ff;
    }

    .page-header {
        text-align: center;
        margin-bottom: 28px;
    }

    .page-header h1 {
        color: #1e3a5f;
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .page-header p {
        color: #666;
        font-size: 14px;
    }

    .search-box {
        max-width: 420px;
        margin-bottom: 20px;
    }

    .search-box input {
        width: 100%;
        padding: 11px 15px;
        border: 2px solid #dbe8ff;
        border-radius: 10px;
        font-size: 15px;
        outline: none;
        transition: .3s;
    }

    .search-box input:focus {
        border-color: #2f55a4;
        box-shadow: 0 0 0 3px rgba(47,85,164,.08);
    }

    .tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        border-bottom: 2px solid #ddd;
    }

    .tab-btn {
        border: none;
        background: #2f55a4;
        color: white;
        padding: 12px 22px;
        border-radius: 10px 10px 0 0;
        font-weight: bold;
        font-size: 15px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .badge-level {
        background: white;
        color: #2f55a4;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 12px;
    }

    .card-box {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 5px 15px rgba(0,0,0,.08);
    }

    .table-wrap {
        width: 100%;
        overflow-x: auto;
    }

    .dept-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin-top: 10px;
    }

    .dept-table thead tr {
        background: #2f55a4;
        color: white;
    }

    .dept-table thead th {
        padding: 14px 18px;
        font-weight: 600;
        font-size: 14px;
        text-align: left;
    }

    .dept-table tbody tr {
        border-bottom: 1px solid #eef2ff;
        transition: .2s;
    }

    .dept-table tbody tr:hover {
        background: #f5f8ff;
    }

    .dept-table tbody td {
        padding: 14px 18px;
        font-size: 14px;
        color: #333;
    }

    .dept-name {
        color: #2f55a4;
        font-weight: bold;
    }

    .gpa-badge {
        background: #eef2ff;
        color: #2f55a4;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 12px;
        font-weight: bold;
    }

    .num-cell {
        color: #888;
        font-weight: bold;
    }

    .no-results {
        text-align: center;
        color: #888;
        padding: 30px;
        font-size: 15px;
    }
</style>

<section class="px-10 pt-6">

    <div class="page-header">
        <h1>Departments</h1>
        <p>Browse all departments in the college</p>
    </div>

    <!-- Search -->
    <div class="search-box">
        <input type="text"
               id="searchInput"
               placeholder="Search departments by name"
               onkeyup="searchDepartments()" />
    </div>

    <!-- Tabs -->
    <div class="tabs">
        <button class="tab-btn">
            Departments
            <span class="badge-level">@departments.Count</span>
        </button>
    </div>

    <!-- Table -->
    <div class="card-box">

        <h4 style="color:#2f55a4; margin-bottom:20px; font-size:17px;">
            All Departments -
            <span style="color:#555;">@departments.Count</span>
        </h4>

        @if (departments.Any())
        {
                <div class="table-wrap">
                    <table class="dept-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Department Name</th>
                                <th>GPA Required</th>
                            </tr>
                        </thead>

                        <tbody>
                        @foreach (var dept in departments)
                        {
                                    <tr class="dept-row">
                                        <td class="num-cell">@dept.ID</td>
                                        <td class="dept-name">@dept.Name</td>
                                        <td>
                                            <span class="gpa-badge">
                                        @dept.GPARequired
                                            </span>
                                        </td>
                                    </tr>
                        }
                        </tbody>
                    </table>
                </div>

                <div class="no-results" id="noResults" style="display:none;">
                    No departments found matching your search.
                </div>
        }
        else
        {
                <div class="no-results">
                    No departments found.
                </div>
        }

    </div>
</section>

<script>
    function searchDepartments() {
        var input = document.getElementById("searchInput").value.toLowerCase();
        var rows = document.querySelectorAll(".dept-row");
        var visibleCount = 0;

        rows.forEach(function (row) {
            var name = row.querySelector(".dept-name").textContent.toLowerCase();

            if (name.includes(input)) {
                row.style.display = "";
                visibleCount++;
            } else {
                row.style.display = "none";
            }
        });

        document.getElementById("noResults").style.display =
            visibleCount === 0 ? "block" : "none";
    }
</script>