@using System.Linq
@using CollegeSystem.Models

@{
    var role = Context.Session.GetString("Role");
    Layout = string.IsNullOrEmpty(role) ? "_LayoutHome" : "_Layout";
    ViewData["Title"] = "DEPI College";
}

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Segoe UI',sans-serif;
    }

    body {
        background: #f4f7fb;
    }
    /*================ NAVBAR =================*/

    .navbar {
        width: 100%;
        height: 85px;
        background: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 8%;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 999;
        box-shadow: 0 8px 25px rgba(0,0,0,.08);
    }

    .logo {
        font-size: 30px;
        font-weight: bold;
        color: #0A2540;
    }

    .menu {
        display: flex;
        gap: 35px;
        list-style: none;
    }

        .menu a {
            text-decoration: none;
            font-size: 17px;
            font-weight: 600;
            color: #444;
            transition: .3s;
        }

            .menu a:hover {
                color: #2563eb;
            }

    .login-btn {
        background: #2563eb;
        color: white;
        padding: 12px 30px;
        border-radius: 30px;
        text-decoration: none;
        font-weight: bold;
        transition: .4s;
    }

        .login-btn:hover {
            background: #0d47c4;
        }
    /*================ HERO =================*/

    .hero {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 120px 8%;
        background: linear-gradient(rgba(5,32,74,.75),rgba(5,32,74,.75)), url('/images/hero.jpg');
        background-size: cover;
        background-position: center;
        color: white;
    }

    .hero-content {
        max-width: 800px;
    }

    .hero h1 {
        font-size: 70px;
        margin-bottom: 20px;
        font-weight: bold;
    }

    .hero p {
        font-size: 22px;
        line-height: 1.8;
        margin-bottom: 35px;
    }

    .hero-buttons {
        display: flex;
        justify-content: center;
        gap: 20px;
    }

    .btn-primary,
    .btn-secondary {
        padding: 16px 35px;
        border-radius: 35px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-primary {
        background: #2563eb;
        color: white;
    }

    .btn-secondary {
        background: white;
        color: #2563eb;
    }
    /*================ STATISTICS =================*/

    .stats {
        width: 100%;
        padding: 80px 8%;
        display: flex;
        justify-content: center;
        gap: 30px;
        background: #f4f7fb;
        flex-wrap: wrap;
    }

    .stat-card {
        width: 250px;
        background: white;
        border-radius: 20px;
        padding: 40px;
        text-align: center;
        box-shadow: 0 15px 35px rgba(0,0,0,.08);
        transition: .4s;
    }

        .stat-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 25px 50px rgba(37,99,235,.25);
        }

        .stat-card h2 {
            color: #2563eb;
            font-size: 50px;
            margin-bottom: 10px;
        }

        .stat-card p {
            color: #666;
            font-size: 20px;
            font-weight: 600;
        }
    /*================ WHY =================*/

    .why {
        padding: 100px 8%;
        text-align: center;
        background: white;
    }

        .why h2 {
            font-size: 45px;
            color: #0A2540;
            margin-bottom: 20px;
        }

    .why-text {
        width: 60%;
        margin: auto;
        color: #666;
        font-size: 20px;
        margin-bottom: 60px;
        line-height: 1.8;
    }

    .why-container {
        display: flex;
        justify-content: center;
        gap: 30px;
        flex-wrap: wrap;
    }

    .why-card {
        width: 330px;
        background: #f8fbff;
        padding: 40px;
        border-radius: 20px;
        transition: .4s;
        box-shadow: 0 15px 30px rgba(0,0,0,.06);
    }

        .why-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 45px rgba(37,99,235,.2);
        }

    .icon {
        font-size: 55px;
        margin-bottom: 20px;
    }

    .why-card h3 {
        color: #0A2540;
        margin-bottom: 15px;
    }

    .why-card p {
        color: #666;
        line-height: 1.7;
    }
    /*================ FEATURED =================*/

    .featured {
        padding: 100px 8%;
        background: #f4f7fb;
        text-align: center;
    }

        .featured h2 {
            font-size: 45px;
            color: #0A2540;
            margin-bottom: 60px;
        }

    .featured-container {
        display: flex;
        justify-content: center;
        gap: 30px;
        flex-wrap: wrap;
    }

    .featured-card {
        width: 340px;
        background: white;
        border-radius: 20px;
        padding: 40px 30px;
        box-shadow: 0 15px 35px rgba(0,0,0,.08);
        transition: .4s;
    }

        .featured-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 25px 45px rgba(37,99,235,.20);
        }

    .college-icon {
        font-size: 60px;
        margin-bottom: 20px;
    }

    .featured-card h3 {
        color: #0A2540;
        margin-bottom: 15px;
    }

    .featured-card p {
        color: #666;
        line-height: 1.8;
        margin-bottom: 25px;
    }

    .featured-card a {
        text-decoration: none;
        color: #2563eb;
        font-weight: bold;
    }
    /*================ FOOTER =================*/

    .footer {
        background: #0A2540;
        color: white;
        padding: 70px 8% 25px;
    }

    .footer-content {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 40px;
    }

    .footer-box {
        width: 300px;
    }

        .footer-box h3 {
            margin-bottom: 20px;
            font-size: 24px;
        }

        .footer-box p {
            color: #ddd;
            line-height: 1.8;
        }

        .footer-box a {
            display: block;
            color: #ddd;
            text-decoration: none;
            margin-bottom: 12px;
            transition: .3s;
        }

            .footer-box a:hover {
                color: #4f8cff;
            }

    .footer hr {
        margin: 40px 0 20px;
        border: none;
        border-top: 1px solid rgba(255,255,255,.2);
    }

    .copyright {
        text-align: center;
        color: #bbb;
    }
</style>

<!-- ================= NAVBAR ================= -->

<nav class="navbar">

    <div class="logo">
        🎓 DEPI College
    </div>

    <a asp-controller="Account"
           asp-action="Login"
           class="login-btn">

        Login

    </a>

</nav>
<section class="hero">

    <div class="hero-content">

        <h1>Discover Your Future</h1>

        <p>
            Build your career with modern education,
            experienced professors and innovative learning.
        </p>

        <div class="hero-buttons">

            <a href="#colleges" class="btn-primary">
                Explore Colleges
            </a>

            <a href="#contact" class="btn-secondary">
                Apply Now
            </a>

        </div>

    </div>

</section>
<!-- ================= STATISTICS ================= -->

<section class="stats">

    <div class="stat-card">
        <h2>15+</h2>
        <p>Colleges</p>
    </div>

    <div class="stat-card">
        <h2>300+</h2>
        <p>Professors</p>
    </div>

    <div class="stat-card">
        <h2>8000+</h2>
        <p>Students</p>
    </div>

    <div class="stat-card">
        <h2>120+</h2>
        <p>Courses</p>
    </div>

</section>
<section class="why">

    <h2>Why Choose DEPI College?</h2>

    <p class="why-text">
        We provide high-quality education with modern technology,
        experienced professors and practical learning.
    </p>

    <div class="why-container">

        <div class="why-card">
            <div class="icon">🎓</div>
            <h3>Quality Education</h3>
            <p>Learn from experienced professors using modern teaching methods.</p>
        </div>

        <div class="why-card">
            <div class="icon">💻</div>
            <h3>Modern Technology</h3>
            <p>Advanced labs and digital learning environment.</p>
        </div>

        <div class="why-card">
            <div class="icon">🌍</div>
            <h3>Career Ready</h3>
            <p>Programs designed to prepare students for the real world.</p>
        </div>

    </div>

</section>
<!-- ================= FEATURED COLLEGES ================= -->

<section class="featured">

    <h2>Our Faculties</h2>

    <div class="featured-container">

        <div class="featured-card">
            <div class="college-icon">💻</div>
            <h3>Computer Science</h3>
            <p>Programming, Artificial Intelligence, Cyber Security and Software Engineering.</p>
            <a href="#">Learn More →</a>
        </div>

        <div class="featured-card">
            <div class="college-icon">🏗️</div>
            <h3>Engineering</h3>
            <p>Mechanical, Civil, Electrical and Architecture Engineering.</p>
            <a href="#">Learn More →</a>
        </div>

        <div class="featured-card">
            <div class="college-icon">💼</div>
            <h3>Business</h3>
            <p>Accounting, Marketing, Finance and Business Administration.</p>
            <a href="#">Learn More →</a>
        </div>

    </div>

</section>
<!-- ================= FOOTER ================= -->

<footer class="footer">

    <div class="footer-content">

        <div class="footer-box">
            <h3>DEPI College</h3>
            <p>
                Empowering students with quality education,
                innovation and real-world skills.
            </p>
        </div>

        <div class="footer-box">
            <h3>Contact</h3>

            <p>📍 Cairo, Egypt</p>
            <p>📧 info@depicollege.com</p>
            <p>📞 +20 100 123 4567</p>

        </div>

    </div>

    <hr>

    <p class="copyright">
        © 2026 DEPI College. All Rights Reserved.
    </p>

</footer>