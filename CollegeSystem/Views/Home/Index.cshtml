@using System.Linq
@using CollegeSystem.Models

@{
    Layout = "_LayoutHome";
    ViewData["Title"] = "DEPI College";
}

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Segoe UI', sans-serif;
  color: #222;
}

/* HERO */
.hero {
  background: #00174d;
  color: white;
  padding: 80px 40px;
  text-align: center;
}
.hero h1 { font-size: 48px; margin-bottom: 16px; }
.hero p { font-size: 18px; opacity: 0.8; margin-bottom: 30px; }
.hero a {
  background: white;
  color: #00174d;
  padding: 12px 30px;
  border-radius: 8px;
  text-decoration: none;
  font-weight: bold;
}

/* SECTION */
.section {
  padding: 60px 40px;
  max-width: 1100px;
  margin: auto;
}
.section-title {
  font-size: 28px;
  margin-bottom: 10px;
}
.section-subtitle {
  color: gray;
  margin-bottom: 30px;
}

.divider {
  border: none;
  border-top: 1px solid #eee;
}

/* ABOUT + DEPARTMENTS */
.about-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
  gap: 20px;
}
.about-card {
  background: #f5f7fb;
  padding: 20px;
  border-radius: 12px;
  text-align: center;
}

/* COURSES */
.courses-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px,1fr));
  gap: 20px;
}
.course-card {
  background: white;
  border-radius: 16px;
  padding: 22px;
  transition: 0.3s;
  border: 1px solid #eee;
}
.course-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

/* PROFESSORS */
.profs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
  gap: 20px;
}
.prof-card {
  background: white;
  padding: 24px;
  border-radius: 16px;
  text-align: center;
  transition: 0.3s;
  border: 1px solid #eee;
}
.prof-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}
.prof-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg,#00174d,#0033aa);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: auto;
  font-size: 22px;
  font-weight: bold;
  margin-bottom: 12px;
}

/* FOOTER */
.footer {
  background: #00174d;
  color: white;
  text-align: center;
  padding: 20px;
}
</style>

<!-- HERO -->
<div class="hero">
    <h1>Welcome to DEPI College</h1>
    <p>Empowering students with knowledge and skills.</p>
    <a asp-controller="Account" asp-action="Login">Login</a>
</div>

<!-- ABOUT -->
<div class="section">
    <p class="section-title">About Us</p>
    <p class="section-subtitle">We provide high-quality education for future leaders.</p>

    <div class="about-grid">
        <div class="about-card"><h3>🎓 Quality Education</h3><p>Modern learning methods.</p></div>
        <div class="about-card"><h3>👨‍🏫 Expert Professors</h3><p>Experienced teaching staff.</p></div>
        <div class="about-card"><h3>🌍 Career Ready</h3><p>Prepare for real jobs.</p></div>
        <div class="about-card"><h3>💡 Innovation</h3><p>Creative environment.</p></div>
    </div>
</div>

<hr class="divider" />

<!-- DEPARTMENTS -->
<div class="section">
    <p class="section-title">Our Departments</p>
    <p class="section-subtitle">Choose your field of study.</p>

    <div class="about-grid">
        <div class="about-card"><h3>💻 Computer Science</h3></div>
        <div class="about-card"><h3>📊 Business</h3></div>
        <div class="about-card"><h3>🏗 Engineering</h3></div>
        <div class="about-card"><h3>🎨 Design</h3></div>
    </div>
</div>

<hr class="divider" />

<!-- COURSES -->
<div class="section">
    <p class="section-title">Courses</p>

    <div class="courses-grid">
        @if (ViewBag.Courses != null && ((IEnumerable<Course>)ViewBag.Courses).Any())
        {
            foreach (var course in (IEnumerable<Course>)ViewBag.Courses)
            {
                        <div class="course-card">
                            <h3>@course.Name</h3>
                            <p>@(course.Description ?? "No description")</p>
                            <p>Duration: @course.Duration</p>
                    @if (course.Professor != null)
                    {
                                    <p>@course.Professor.Name</p>
                    }
                        </div>
            }
        }
        else
        {
                <p>No courses available</p>
        }
    </div>
</div>

<hr class="divider" />

<!-- PROFESSORS -->
<div class="section">
    <p class="section-title">Professors</p>

    <div class="profs-grid">
        @if (ViewBag.Professors != null && ((IEnumerable<Professor>)ViewBag.Professors).Any())
        {
            foreach (var prof in (IEnumerable<Professor>)ViewBag.Professors)
            {
                        <div class="prof-card">
                            <div class="prof-avatar">@prof.Name?.FirstOrDefault()</div>
                            <h3>@prof.Name</h3>
                            <p>@prof.Email</p>
                        </div>
            }
        }
        else
        {
                <p>No professors available</p>
        }
    </div>
</div>

<!-- FOOTER -->
<div class="footer">
    <p>© 2026 DEPI College</p>
</div>