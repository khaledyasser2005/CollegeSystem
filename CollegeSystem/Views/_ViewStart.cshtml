@{

    var role = Context.Session.GetString("Role");

    if (Context.Request.Path.StartsWithSegments("/Home") && string.IsNullOrEmpty(role))
    {
        Layout = "_LayoutHome";
    }
    else if (Context.Request.Path.StartsWithSegments("/Account"))
    {
        Layout = "_LayoutLogin";
    }
    else
    {
        Layout = "_Layout";
    }
}
